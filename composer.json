{
    "name": "mavida/mvd-wp-all-import-controller",
    "description": "Plugin WordPress per eseguire importazioni WP All Import Pro in sequenza con un solo click.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "yahnis-elsts/plugin-update-checker": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.11",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "php-stubs/wordpress-stubs": "^6.5"
    },
    "autoload-dev": {
        "psr-4": {
            "MvdWaiCtrl\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "phpstan": "phpstan analyse --configuration phpstan.neon.dist",
        "check": [
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
